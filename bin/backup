#!/usr/bin/mksh
# Script by Ypnose - http://ywstd.fr
# $ ( cd /mnt && backup -f FILELIST -t $HOME BACKUP )

BACK_SUMS="1"
BACK_DATE="$(date '+%Y-%m-%d')"

function p_err {
	print -u2 -- "$1"
	exit 1
}

function usage {
	print "usage: backup [-d] [-f FILELIST] [-h] [-n] [-t] [SRC] [DEST]"
	exit
}

if [[ $1 = "-h" ]]; then
	usage
fi

if [[ ! -x $(whence -p rsync) ]]; then
	p_err "rsync not found in the PATH"
fi

while getopts ":df:nt" opt; do
	case $opt in
		d)
			BACK_DRYR="1"
			BACK_OPTS+=(--dry-run --log-file=/dev/null)
			;;
		f)
			BACK_INCL="$OPTARG"
			;;
		n)
			BACK_SUMS="0"
			;;
		t)
			BACK_SQSH="1"
			;;
		*)
			usage
			;;
	esac
done
shift $(( OPTIND - 1 ))

# SRC and DEST are required
if (( $# < 2 )); then
	usage
fi

BACK_DEST="$2"

if [[ ! -d $BACK_DEST ]]; then
	p_err "$BACK_DEST directory is missing"
fi

if [[ -z $BACK_INCL ]]; then
	p_err "No include file provided"
elif [[ ! -r $BACK_INCL ]]; then
	p_err "$BACK_INCL is either missing or unreadable"
fi

# Check rsync(1) man page for pattern rules
# With '--files-from', '-r' needs to be specified explicitly
rsync \
	-ahrvHX \
	--checksum \
	--delete \
	--delete-delay \
	--exclude=".gnupg/random_seed" \
	--exclude=".gnupg/S.*" \
	--exclude=".gnupg/gpg*.conf" \
	--exclude=".ssh/agent/" \
	--exclude="*.dump" \
	--exclude="*.qcow2*" \
	--exclude="*.raw" \
	--exclude="Desktop/" \
	--exclude="Downloads/" \
	--files-from="$BACK_INCL" \
	--log-file="${BACK_DEST}/rsync-$(hostname)-${BACK_DATE}.log" \
	--numeric-ids \
	--stats \
	"${BACK_OPTS[@]}" \
	"$1" "$BACK_DEST"

if (( BACK_DRYR != 1 )); then
	# Calculate checksums
	if (( BACK_SUMS == 1 )); then
		if [[ ! -x $(whence -p b3sum) ]]; then
			p_err "b3sum not found in the PATH"
		fi
		find "$BACK_DEST" -type f -exec b3sum {} \+ >"B3SUMS_${BACK_DEST}"
	fi
	# Create a Squashfs filesystem
	if (( BACK_SQSH == 1 )); then
		sleep 5
		mksquashfs \
			"$BACK_DEST" \
			"BACKUP-$(hostname)-${BACK_DATE}.sqsh" \
			-comp gzip \
			-keep-as-directory \
			-reproducible \
			-xattrs
	fi
	sync
fi

exit
